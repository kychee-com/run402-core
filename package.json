{
  "name": "run402-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Open-source Run402 server/runtime core.",
  "workspaces": [
    "packages/functions",
    "packages/release",
    "packages/runtime-kernel",
    "apps/core-gateway"
  ],
  "scripts": {
    "build": "npm run build:functions && npm run build:release && npm run build:runtime-kernel && npm run build:core-gateway",
    "test": "npm run build:functions && npm run build:release && npm run build:runtime-kernel && npm run test:functions && npm run test:release && npm run test:runtime-kernel && npm run test:core-gateway",
    "build:functions": "npm run build -w packages/functions",
    "build:release": "npm run build -w packages/release",
    "build:runtime-kernel": "npm run build -w packages/runtime-kernel",
    "build:core-gateway": "npm run build -w apps/core-gateway",
    "test:functions": "npm run test -w packages/functions",
    "test:functions:smoke": "node packages/functions/test/smoke-tarball.mjs",
    "test:release": "npm run test -w packages/release",
    "test:release:smoke": "node packages/release/test/smoke-tarball.mjs",
    "test:runtime-kernel": "npm run test -w packages/runtime-kernel",
    "test:core-gateway": "npm run test -w apps/core-gateway",
    "lint": "npm run lint:functions && npm run build:functions && npm run lint:release && npm run build:release && npm run lint:runtime-kernel && npm run build:runtime-kernel && npm run lint:core-gateway",
    "lint:functions": "tsc --noEmit -p packages/functions/tsconfig.json",
    "lint:release": "npm run lint -w packages/release",
    "lint:runtime-kernel": "npm run lint -w packages/runtime-kernel",
    "lint:core-gateway": "npm run lint -w apps/core-gateway",
    "pack:release": "npm pack -w packages/release --dry-run",
    "clean:release": "npm run clean -w packages/release",
    "core:health": "node scripts/core-health.mjs",
    "core:smoke": "node scripts/core-project-smoke.mjs",
    "core:apply-smoke": "node scripts/core-apply-smoke.mjs",
    "core:storage-routing": "node scripts/core-storage-routing-smoke.mjs",
    "core:functions": "node scripts/core-functions-smoke.mjs",
    "core:astro-ssr": "node scripts/core-astro-ssr-smoke.mjs",
    "core:conformance": "npm run core:apply-smoke && npm run core:storage-routing && npm run core:functions && npm run core:astro-ssr",
    "core:boundary": "node scripts/core-boundary-check.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
