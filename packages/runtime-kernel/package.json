{
  "name": "@run402/runtime-kernel",
  "version": "0.2.0",
  "description": "Public Run402 Core runtime kernel contracts, capabilities, and application services.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas/*": "./schemas/*"
  },
  "files": [
    "dist",
    "schemas",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "node --test --import tsx 'src/**/*.test.ts'"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@run402/functions": "3.5.6",
    "@run402/release": "0.3.0",
    "croner": "^10.0.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kychee-com/run402-core.git",
    "directory": "packages/runtime-kernel"
  },
  "homepage": "https://run402.com",
  "bugs": "https://github.com/kychee-com/run402-core/issues",
  "author": "Kychee Technologies",
  "license": "Apache-2.0",
  "keywords": [
    "run402",
    "core",
    "runtime",
    "postgres",
    "postgrest",
    "storage",
    "routing",
    "ai-agent"
  ],
  "publishConfig": {
    "access": "public"
  }
}
